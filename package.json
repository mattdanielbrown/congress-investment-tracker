{
	"name": "congress-stock-disclosure-tracker",
	"version": "0.1.0",
	"private": true,
	"description": "A TypeScript data pipeline for tracking publicly reported congressional stock disclosures with source audit trails.",
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"start": "node dist/index.js",
		"dev": "tsx src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"congress",
		"financial-disclosures",
		"civic-data",
		"typescript",
		"postgresql"
	],
	"license": "UNLICENSED",
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"dotenv": "^16.4.7",
		"pg": "^8.13.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/pg": "^8.11.10",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
